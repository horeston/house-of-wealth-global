<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The House of Wealth | High Watt Solutions</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Times New Roman', serif; }
        body { background-color: #030b1e; color: #ffffff; min-height: 100vh; overflow-x: hidden; position: relative; }
        
        /* Gold Outer Frame */
        body::after { content: ''; position: fixed; top: 0; left: 0; width: 100%; height: 100%; border: 4px solid #d4af37; pointer-events: none; z-index: 100; }

        /* Top Navigation Link Ribbon */
        header { width: 100%; padding: 30px 20px; text-align: center; position: relative; z-index: 10; }
        nav a { color: #ffffff; text-decoration: none; font-size: 1.1rem; margin: 0 15px; letter-spacing: 1px; }
        nav a:hover, nav a.active { color: #e5c158; text-shadow: 0 0 10px #e5c158; }
        nav span { color: #d4af37; opacity: 0.5; }

        /* The 3-Column Layout Template */
        .main-canvas { display: flex; justify-content: space-between; align-items: center; max-width: 1400px; margin: 0 auto; padding: 20px 40px; min-height: calc(100vh - 160px); }

        /* Left and Right Visual Art Columns */
        .art-column { width: 25%; text-align: center; }
        .art-column img { width: 100%; height: auto; max-height: 500px; object-fit: contain; }

        /* Center Column Content */
        .center-content { width: 45%; text-align: center; display: flex; flex-direction: column; align-items: center; }
        .logo-graphic { width: 180px; height: auto; margin-bottom: 20px; }
        
        .title-top { font-size: 1.6rem; color: #d4af37; text-transform: uppercase; letter-spacing: 4px; margin-bottom: 10px; }
        .title-main { font-size: 3.5rem; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; line-height: 1.1; margin-bottom: 20px; }
        .tagline { font-size: 1.2rem; color: #cbd5e1; margin-bottom: 35px; font-style: italic; }

        /* Action Buttons */
        .button-box { display: flex; gap: 20px; }
        .btn { display: inline-block; padding: 14px 35px; font-size: 1rem; font-weight: bold; text-transform: uppercase; text-decoration: none; letter-spacing: 1.5px; border-radius: 30px; transition: all 0.3s ease; }
        .btn-gold { background: linear-gradient(135deg, #d4af37 0%, #aa8214 100%); color: #030b1e; border: 1px solid #e5c158; }
        .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(212, 175, 55, 0.4); }
        .btn-outline { background: transparent; color: #ffffff; border: 2px solid #d4af37; }
        .btn-outline:hover { background: rgba(212, 175, 55, 0.1); transform: translateY(-2px); }

        /* Footer Bar */
        footer { width: 100%; padding: 20px 40px; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(212, 175, 55, 0.2); background: rgba(3, 11, 30, 0.9); position: relative; z-index: 10; }
        .footer-brand { color: #d4af37; letter-spacing: 2px; text-transform: uppercase; font-size: 0.9rem; }
    </style>
</head>
<body>

    <!-- Header Navigation -->
    <header>
        <nav>
            <a href="#" class="active">Home</a> <span>|</span>
            <a href="#">Services</a> <span>|</span>
            <a href="#">Case Studies</a> <span>|</span>
            <a href="#">About</a> <span>|</span>
            <a href="#">Contact</a>
        </nav>
    </header>

    <!-- Main Visual Canvas -->
    <main class="main-canvas">
        
        <!-- Left Side: Natural Pillars Graphics -->
        <section class="art-column">
            <img src="left-natural.png" alt="Organic Abundance Pillar">
        </section>

        <!-- Center Focus: Branding and Buttons -->
        <section class="center-content">
            <img src="center-logo.png" alt="HW Gold Lightning Logo" class="logo-graphic">
            
            <h2 class="title-top">The House of Wealth</h2>
            <h1 class="title-main">High Watt Solutions</h1>
            <p class="tagline">Unlock the energy of innovation with our precision platforms.</p>
            
            <div class="button-box">
                <a href="#" class="btn btn-outline">Explore Services</a>
                <!-- The Refined Action Call -->
                <a href="#" class="btn btn-gold">Join the Family Now</a>
            </div>
        </section>

        <!-- Right Side: Technological Infrastructure Graphics -->
        <section class="art-column">
            <img src="right-tech.png" alt="High-Watt Infrastructure Pillar">
        </section>

    </main>

    <!-- Footer Strip -->
    <footer>
        <div class="footer-brand">★ HW ★</div>
        <div class="footer-brand">House of Wealth</div>
        <div class="footer-brand">🪪 ✉ 🌐</div>
    </footer>

</body>
</html>